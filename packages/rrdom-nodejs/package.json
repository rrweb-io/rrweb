{
  "name": "@amplitude/rrdom-nodejs",
  "version": "2.1.2",
  "scripts": {
    "dev": "vite build --watch",
    "build": "turbo run prepublish",
    "check-types": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepublish": "tsc -noEmit && vite build",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "rrweb",
    "rrdom-nodejs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amplitude/rrweb.git"
  },
  "type": "module",
  "main": "./dist/rrdom-nodejs.umd.cjs",
  "module": "./dist/rrdom-nodejs.js",
  "unpkg": "./dist/rrdom-nodejs.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/rrdom-nodejs.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/rrdom-nodejs.umd.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "@types/cssom": "^0.4.1",
    "@types/cssstyle": "^2.2.1",
    "@types/nwsapi": "^2.2.2",
    "@types/puppeteer": "^5.4.4",
    "@typescript-eslint/eslint-plugin": "^5.23.0",
    "@typescript-eslint/parser": "^5.23.0",
    "compare-versions": "^4.1.3",
    "eslint": "^8.15.0",
    "puppeteer": "^9.1.1",
    "typescript": "^5.4.5",
    "vite": "^6",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "@amplitude/rrdom": "workspace:^",
    "@amplitude/rrweb-types": "workspace:^",
    "cssom": "^0.5.0",
    "cssstyle": "^2.3.0",
    "nwsapi": "2.2.0"
  }
}
