{
  "name": "@amplitude/rrdom",
  "version": "2.1.0",
  "homepage": "https://github.com/rrweb-io/rrweb/tree/main/packages/rrdom#readme",
  "license": "MIT",
  "type": "module",
  "main": "./dist/rrdom.cjs",
  "module": "./dist/rrdom.js",
  "unpkg": "./dist/rrdom.umd.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/rrdom.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/rrdom.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amplitude/rrweb.git"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "turbo run prepublish",
    "check-types": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublish": "tsc -noEmit && vite build",
    "lint": "eslint src/**/*.ts"
  },
  "bugs": {
    "url": "https://github.com/rrweb-io/rrweb/issues"
  },
  "devDependencies": {
    "@amplitude/rrweb-types": "workspace:^",
    "@types/jsdom": "^20.0.0",
    "jsdom": "^16.7.0",
    "@typescript-eslint/eslint-plugin": "^5.23.0",
    "@typescript-eslint/parser": "^5.23.0",
    "eslint": "^8.15.0",
    "puppeteer": "^20.9.0",
    "typescript": "^5.4.5",
    "vite": "^6",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "@amplitude/rrweb-snapshot": "workspace:^"
  }
}
