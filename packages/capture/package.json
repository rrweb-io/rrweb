{
  "name": "@amplitude/rrweb-capture",
  "version": "2.1.2",
  "description": "High-level DOM capture utility built on rrweb-snapshot",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "rrweb",
    "capture",
    "snapshot"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -noEmit && vite build",
    "check-types": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepublish": "npm run build",
    "lint": "eslint src/**/*.ts"
  },
  "type": "module",
  "main": "./dist/rrweb-capture.umd.cjs",
  "module": "./dist/rrweb-capture.js",
  "unpkg": "./dist/rrweb-capture.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/rrweb-capture.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/rrweb-capture.umd.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amplitude/rrweb.git"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "jsdom": "^16.7.0",
    "vite": "^6",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "@amplitude/rrweb-snapshot": "workspace:^",
    "@amplitude/rrweb-types": "workspace:^"
  }
}
