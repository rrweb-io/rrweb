{
  "name": "@grafana/rrweb-record",
  "version": "2.0.0-grafana.1",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "rrweb",
    "@grafana/rrweb-record"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "turbo run prepublish",
    "retest": "vitest run",
    "test": "npm run build && vitest run",
    "test:watch": "vitest watch",
    "check-types": "tsc -noEmit",
    "prepublish": "tsc -noEmit && vite build",
    "lint": "eslint src/**/*.ts"
  },
  "homepage": "https://github.com/rrweb-io/rrweb/tree/main/packages/@rrweb/record#readme",
  "bugs": {
    "url": "https://github.com/grafana/rrweb/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grafana/rrweb"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/rrweb-record.cjs",
  "module": "./dist/rrweb-record.js",
  "unpkg": "./dist/rrweb-record.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/rrweb-record.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/rrweb-record.cjs"
      }
    }
  },
  "files": [
    "umd",
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "puppeteer": "^20.9.0",
    "vite": "^6.0.1",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.4.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@grafana/rrweb-types": "^2.0.0-grafana.1",
    "@grafana/rrweb": "^2.0.0-grafana.1",
    "@grafana/rrweb-utils": "^2.0.0-grafana.1"
  },
  "browserslist": [
    "supports es6-class"
  ]
}
